// Settings app rendered with the Dust component library.
// Root contract: #PhoneNumberLabel (device id), #ThemeLabel (current theme),
// and the three theme buttons #ThemeDefault / #ThemeDark / #ThemeCompact, which
// SettingsApp binds. FlexWeight:1 lets the panel fill the shell content area.
$D = "../DustLib.ui";

Group {
  FlexWeight: 1;
  LayoutMode: Top;

  $D.@DustShellHeader #SettingsHeader { @Title = "Settings"; }

  $D.@DustShellPanel #SettingsPanel {
    FlexWeight: 1;

    Group #DeviceNumberSection {
      LayoutMode: Top;
      Anchor: (Bottom: $D.@DustShellSpacing);

      Label {
        Text: "Phone Number";
        Anchor: (Bottom: 6);
        Style: (FontSize: 12, TextColor: $D.@DustTextSecondary);
      }
      Label #PhoneNumberLabel {
        Text: "---";
        Style: (FontSize: 18, RenderBold: true, TextColor: $D.@DustTextPrimary);
      }
    }

    Group #ThemeSection {
      LayoutMode: Top;

      Label #ThemeLabel {
        Text: "Theme";
        Anchor: (Bottom: 6);
        Style: (FontSize: 12, TextColor: $D.@DustTextSecondary);
      }
      $D.@DustShellSecondaryButton #ThemeDefault { Anchor: (Height: 36, Bottom: 6); Text: "Default"; }
      $D.@DustShellSecondaryButton #ThemeDark    { Anchor: (Height: 36, Bottom: 6); Text: "Dark"; }
      $D.@DustShellSecondaryButton #ThemeCompact { Anchor: (Height: 36); Text: "Compact"; }
    }
  }
}
