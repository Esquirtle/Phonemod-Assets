// Contacts app rendered with the Dust component library.
// Root contract: #AddContactButton, #ContactsList.
$D = "../DustLib.ui";

Group {
  LayoutMode: Top;

  $D.@DustShellHeader #ContactsHeader { @Title = "Contacts"; }

  // Add-contact action. Kept as a top-level sibling (not embedded in the header
  // template) so we only override the button instance's own properties.
  $D.@DustShellSecondaryButton #AddContactButton {
    Anchor: (Height: 32, Bottom: $D.@DustShellSpacing);
    Text: "Add Contact";
  }

  Group #ContactsPanel {
    LayoutMode: Top;
    Background: $D.@DustPanelBackground;
    Padding: (Full: $D.@DustPanelPadding);

    // Scrolling contacts list. Themeable background (role: appContent).
    Group #ContactsList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Background: $D.@DustShellListEntryBackground;
      Padding: (Full: $D.@DustPanelPadding);
    }
  }
}
