$D = "../DustLib.ui";

// ── Phone shell geometry ────────────────────────────────────────────────────
// The device is a fixed-size window pinned to the lower-right of the screen.
// The screen insets below are calibrated to the PhoneBGTEST.png frame art — the
// visible "glass" sits inside the painted bezel, so content is inset on all
// sides. Tune these together with the frame image, not independently.
@DeviceWide       = 316;
@DeviceHeight     = 650;
@ScreenInsetX     = 4;    // left/right bezel (symmetric)
@ScreenInsetTop   = 70;   // top bezel (speaker/camera band)
@ScreenInsetBot   = 8;    // gap above the home bar
@StatusBarHeight  = 28;

Group #PhoneOverlay {
  Background: PatchStyle(Color: #000000(0.2));

  Group #Device {
    Anchor: (Height: @DeviceHeight, Width: @DeviceWide, Right: 140, Bottom: 60);
    Background: "../Playground/PhoneBGTEST.png";
    LayoutMode: Top;

    // Screen "glass": fills the device above the home bar, inset by the bezel.
    Group #ScreenContent {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Top: @ScreenInsetTop, Horizontal: @ScreenInsetX, Bottom: @ScreenInsetBot);

      // App content area. Apps and the home grid load into #AppContent
      // (the device ContentSelector); it fills the remaining screen height.
      Group #AppContent {
        FlexWeight: 1;
        LayoutMode: Top;

        // Status bar. Themed at runtime (device selector role: topbar); the Dust
        // token below is just the pre-theme default so it matches the dark shell.
        Group #TopBar {
          Anchor: (Height: @StatusBarHeight);
          LayoutMode: Left;
          Background: $D.@DustShellTopbarBackground;
          Label {
            FlexWeight: 1;
            Padding: (Horizontal: 8);
            Text: "HyTel";
            Style: (FontSize: 12, RenderBold: true, TextColor: $D.@DustTextPrimary);
          }
          Group #HytelLogo {
            Background: "../Phone/hytel_logo.png";
            Anchor: (Width: 20, Height: 20);
          }
          Group #BatteryIcon {
            Background: "../Phone/battery_icon.png";
            Anchor: (Width: 20, Height: 20, Left: 6, Right: 4);
          }
        }

        // Home app grid (rebuilt by the framework).
        Group #APPHolder {
          FlexWeight: 1;
          Padding: (Full: 8);
          LayoutMode: LeftCenterWrap;
        }
      }
    }

    // Persistent home bar. Chrome + selectors (#BottomBar/#HomeButton) from DustLib.
    $D.@DustHomeBar #BottomBar { }
  }
}
