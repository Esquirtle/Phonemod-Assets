$Common = "../../Common.ui";
$APPMENU = "MainApp.ui";
// Full-screen dimmed overlay — centers the phone window
@DeviceWide = 285*1.3;
@DeviceHeight = 510*1.3;
@ScreenWide = @DeviceWide - 44;
@ScreenHeight = @DeviceHeight - 26;
Group #PhoneOverlay {
  Background: PatchStyle(Color: #000000(0.2));

  Group #Device {
    Anchor: (Height: @DeviceHeight, Width: @DeviceWide, Right:140, Bottom: 60);
    Background: "../Playground/PhoneBGTEST.png";
    //Background: PatchStyle(Color: #1a1a1a(0.95), Border: 1);
    LayoutMode: Top;
    // ── Content area — inject app panels here via sendUpdate ──────────────────
    Group #Content {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Top: 50);
      Group #Phone{
        Anchor: (Width: @ScreenWide, Height: @ScreenHeight-80);
        LayoutMode: Top;
        Background: PatchStyle(Color: #3b3b3b(0.5));
        Group #TopBar {
          Background: #333333;
          Label {
            Anchor: (Left: 1);
            Text: "HyTel";
          }
          Group #HytelLogo{
            Background: "../Phone/hytel_logo.png";
            Anchor: (Width: 20, Height: 20, Left: 50);
          }
          Group #BatteryIcon{
            Background: "../Phone/battery_icon.png";
            Anchor: (Width: 20, Height: 20, Right: 1);
          }
        }
        Group #AppContent {
          Anchor: (Width: @ScreenWide-8);
          LayoutMode: Top;
          Group #APPHolder {
            LayoutMode: LeftCenterWrap;
          }
        }
      }
      Group #BottomBar{
        $Common.@TertiaryTextButton #HomeButton {
          @Text = "O";
          Anchor: (Width: 44, Height: 44);
        }
      }
    }
  }
}
