$Common = "../../Common.ui";
$APPMENU = "MainApp.ui";
// Full-screen dimmed overlay — centers the phone window
@DeviceWide = 316;
@DeviceHeight = 650;
@ScreenWide = @DeviceWide - 8;
@ScreenHeight = @DeviceHeight - 12;
Group #PhoneOverlay {
  Background: PatchStyle(Color: #000000(0.2));

  Group #Device {
    Anchor: (Height: @DeviceHeight, Width: @DeviceWide, Right:140, Bottom: 60);
    Background: "../Playground/PhoneBGTEST.png";
    //Background: PatchStyle(Color: #1a1a1a(0.95), Border: 1);
    LayoutMode: Top;
    // ── Content area — inject app panels here via sendUpdate ──────────────────
    Group #ScreenContent {
      FlexWeight: 1;
      LayoutMode: Top;
      Anchor: (Width: @ScreenWide, Height: @ScreenHeight);
      //Background: PatchStyle(Color: #d84646(0.05));
      Group #Phone{
        Padding: (Top:70);
        LayoutMode: Top;
        //Background: PatchStyle(Color: #3b3b3b(0.5));
      
        Group #AppContent {
          LayoutMode: Top;
          Group #TopBar {
            Anchor: (Width: @ScreenWide-3);
            LayoutMode: LeftCenterWrap;
            Background: #333333;
            Label {
              Padding: (Horizontal: 8);
              FlexWeight: 1;
              Text: "HyTel";
            }
            Group #HytelLogo{
              Background: "../Phone/hytel_logo.png";
              Anchor: (Width: 20, Height: 20, Left: 50);
            }
            Group #BatteryIcon{
              Background: "../Phone/battery_icon.png";
              Anchor: (Width: 20, Height: 20, Right: 1);
            }
          }
          Group #APPHolder {
            Padding: (Horizontal: 8, Vertical: 8);
            LayoutMode: LeftCenterWrap;
          }
        }
      }

    }
    Group #BottomBar{
      Padding: (Top: 4);
      $Common.@TertiaryTextButton #HomeButton {
        @Text = "O";
        Anchor: (Width: 44, Height: 44);
      }
    }
  }
}
