$P = "../../PhoneLib.ui";

Group {
  LayoutMode: Top;

  $P.@AppTopbar #ContactTopbar {
    TextButton #BackButton {
      FlexWeight: 1;
      Anchor: (Width: 54, Height: 30);
      Text: "Back";
      Style: (
        Default: (Background: #9e9e9e, LabelStyle: (FontSize: 12, Alignment: Center)),
        Hovered: (Background: #7a7a7a, LabelStyle: (FontSize: 14, Alignment: Center))
      );
    }
    Label #ContactName {
      Padding: (Left: 8);
      FlexWeight: 3;
      Text: "Contact";
    }
    $P.@PrimaryActionButton #CallButton {
      FlexWeight: 1;
      Anchor: (Width: 54, Height: 30);
      Text: "Call";
    }
  }

  $P.@AppContentArea #MessageList {
    Anchor: (Width: 360, Height: 520);
    Background: #cacaca;
  }

  $P.@MessageInputRow #ChatInputRow { }
}
