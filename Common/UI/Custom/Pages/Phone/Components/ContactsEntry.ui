@ChatButtonLabel = LabelStyle (
  FontSize: 10,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);
@RemoveButtonLabel = LabelStyle (
  FontSize: 10,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

Group #ContactsEntry {
  Anchor: (Width: 360, Height: 65);
  LayoutMode: Center;
  Padding: (Full: 8);
  Group {
    Padding: (Horizontal: 8, Vertical: 6);
    LayoutMode: LeftCenterWrap;
    Background: #9db48d;
    Label #ContactName {
      Anchor: (Width: 200, Top: 8);
      Text: "Name (555-0000)";
      Style: (HorizontalAlignment: Center, VerticalAlignment: Center, Wrap: true);
    }

    TextButton #ChatButton {
      Anchor: (Width: 38, Height: 38);
      Text: "Chat";
      Style: (
        Default: (Background: #41c141, LabelStyle: @ChatButtonLabel),
        Hovered: (Background: #2e8b2e, LabelStyle: (FontSize: 14, HorizontalAlignment: Center, VerticalAlignment: Center))
      );
    }

    TextButton #CallButton {
      Anchor: (Width: 38, Height: 38);
      Text: "Call";
      Style: (
        Default: (Background: #43D69A, LabelStyle: (FontSize: 12, HorizontalAlignment: Center, VerticalAlignment: Center)),
        Hovered: (Background: #2eb87d, LabelStyle: (FontSize: 14, HorizontalAlignment: Center, VerticalAlignment: Center))
      );
    }
    TextButton #RemoveButton {
      Anchor: (Width: 38, Height: 38);
      Text: "Remove";
      Style: (
        Default: (Background: #d94f4f, LabelStyle: @RemoveButtonLabel),
        Hovered: (Background: #b03030, LabelStyle: (FontSize: 14, HorizontalAlignment: Center, VerticalAlignment: Center))
      );
    }
  }
}
