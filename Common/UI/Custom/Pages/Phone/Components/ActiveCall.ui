$P = "../../PhoneLib.ui";

Group {
  LayoutMode: Top;

  $P.@AppTopbar #Topbar {
    Label {
      Text: "On Call";
    }
  }

  Group #ActiveCallContent {
    Anchor: (Width: 360, Height: 490);
    Background: #1a1a1a;
    LayoutMode: CenterMiddle;

    Group {
      LayoutMode: Top;

      Label {
        Text: "In call with";
        Style: (FontSize: 13, Alignment: Center);
        Padding: (Bottom: 8);
      }

      Label #PartnerLabel {
        Text: "Unknown";
        Style: (FontSize: 20, Alignment: Center);
        Padding: (Bottom: 40);
      }

      TextButton #HangUpButton {
        Anchor: (Width: 150, Height: 54);
        Text: "Hang Up";
        Style: (
          Default: (Background: #d94f4f, LabelStyle: (FontSize: 12, Alignment: Center)),
          Hovered: (Background: #b03030, LabelStyle: (FontSize: 14, Alignment: Center))
        );
      }
    }
  }
}
