// One contacts-list row, appended into #ContactsList.
// Contract: app sets #ContactName.Text and binds #ChatButton / #CallButton /
// #RemoveButton.
$D = "../../DustLib.ui";

Group #ContactsEntry {
  LayoutMode: Left;
  Anchor: (Height: $D.@DustShellListEntryHeight, Bottom: 6);
  Background: $D.@DustShellListEntryBackground;
  Padding: (Horizontal: 10, Vertical: 8);

  Label #ContactName {
    FlexWeight: 1;
    Text: "Name (555-0000)";
    Style: (FontSize: 13, TextColor: $D.@DustTextPrimary, Wrap: true);
  }
  $D.@DustShellActionButton #ChatButton    { Anchor: (Width: 46, Height: 38, Right: 4); Text: "Chat"; }
  $D.@DustShellSecondaryButton #CallButton { Anchor: (Width: 46, Height: 38, Right: 4); Text: "Call"; }
  $D.@DustShellDangerButton #RemoveButton  { Anchor: (Width: 46, Height: 38); Text: "Del"; }
}
