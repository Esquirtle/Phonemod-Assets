// One call-history row, appended into #CallHistoryList.
// Contract: app sets #ContactName.Text / #CallStatus.Text and binds
// #CallBackButton.
$D = "../../DustLib.ui";

Group #CallHistoryEntry {
  LayoutMode: Left;
  Anchor: (Height: $D.@DustShellListEntryHeight, Bottom: 6);
  Background: $D.@DustShellListEntryBackground;
  Padding: (Horizontal: 10, Vertical: 8);

  Group #CallInfo {
    FlexWeight: 1;
    LayoutMode: Top;

    Label #ContactName {
      Text: "Name (555-0000)";
      Style: (FontSize: 13, TextColor: $D.@DustTextPrimary);
    }
    Label #CallStatus {
      Text: "Outgoing";
      Style: (FontSize: 11, TextColor: $D.@DustTextSecondary);
    }
  }

  $D.@DustShellActionButton #CallBackButton {
    Anchor: (Width: 54, Height: 38);
    Text: "Call";
  }
}
